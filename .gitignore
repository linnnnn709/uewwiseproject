# ==========================================
# UE项目（GAD_UE_LXR）编译缓存 - 必须屏蔽
# ==========================================
GAD_UE_LXR/Intermediate/
GAD_UE_LXR/Saved/
GAD_UE_LXR/DerivedDataCache/
GAD_UE_LXR/Binaries/
GAD_UE_LXR/Build/
GAD_UE_LXR/Platforms/

# ==========================================
# Wwise项目（GAD_WWISE_LXR）音频缓存 - 必须屏蔽
# ==========================================
GAD_WWISE_LXR/GeneratedSoundBanks/
GAD_WWISE_LXR/.cache/
GAD_WWISE_LXR/Cache/
GAD_WWISE_LXR/Intermediate/

# ==========================================
# Visual Studio 垃圾文件
# ==========================================
.vs/
*.sln
*.suo
*.user
*.VC.db
*.VC.opendb
*.sdf
*.opensdf

# ==========================================
# 操作系统垃圾文件
# ==========================================
.DS_Store
Thumbs.db
*.tmp
*.log

# ==========================================
# 备份文件
# ==========================================
*.backup
*.old
*.bak

# ==========================================
# 其他可能的大文件
# ==========================================
*.pdb
*.obj
*.exe
*.dll

# ==========================================
# Wwise SoundEngine 第三方库文件（超大，必须排除）
# ==========================================
GAD_UE_LXR/Plugins/WwiseSoundEngine/ThirdParty/
GAD_UE_LXR/Plugins/Wwise/ThirdParty/
GAD_UE_LXR/Plugins/*/ThirdParty/

# ==========================================
# 所有 .lib 文件（编译产物，不需要上传）
# ==========================================
*.lib
*.pdb
*.obj
*.exp
*.dll
*.exe